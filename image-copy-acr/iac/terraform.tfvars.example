location   = "eastus"
group_name = "your.org.com"

dst_repo_prefix   = "mirrors"
ignore_referrers  = false
verify_signatures = false

# ── Existing ACR (optional) ──────────────────────────────────────────────────
# Leave both commented out to let Terraform create a new ACR automatically.
# Fill in both to reuse an ACR that already exists in your subscription.
#
# existing_acr_name           = "myregistry"
# existing_acr_resource_group = "my-platform-rg"
